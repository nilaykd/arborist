{
  "extends": "../../tsconfig.build.json",
  "compilerOptions": {
    "outDir": "./lib",
    "rootDir": "src",
    "lib": ["DOM", "ES2019"],
    "jsx": "react",
    "skipLibCheck": true,
    "types": ["node", "jest"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "lib", "src/__tests__/**", "**/*-spec.ts"]
}
