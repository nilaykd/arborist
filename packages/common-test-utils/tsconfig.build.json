{
  "extends": "../../tsconfig.build.json",
  "compilerOptions": {
    "outDir": "./lib",
    "rootDir": "src",
    "skipLibCheck": true,
    "typeRoots": [
      "./node_modules/@types",
      "../../node_modules/@types"
    ],
    "types": ["node", "jest"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "lib", "**/*-spec.ts"]
}
